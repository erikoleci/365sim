# Backend (server/) config
PORT=3001
JWT_SECRET=change-this-to-a-long-random-string
API_FOOTBALL_KEY=your_api_football_key_here
# PostgreSQL connection string — e.g. a free database from neon.tech or supabase.com.
# Local dev example: postgresql://postgres:yourpassword@localhost:5432/sim365
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Frontend (Vite) config — used by services/geminiService.ts fallback, optional
API_KEY=your_gemini_api_key_here
